### -----------------------
### ACTIVITIES
### -----------------------
### new activity 
POST {{host}}/activities/new
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "activityName": "Gym"
}

### new activity same user and name
POST {{host}}/activities/new
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "activityName": "Gym"
}

### get all activities by user
GET {{host}}/activities
Authorization: Bearer {{token}}

### get activity detail for a month
GET {{host}}/activities/detail/ec17ae2a-032e-49fc-8cdb-c86a097d3a2d?month=03
Authorization: Bearer {{token}}

### get activity detail for a year
GET {{host}}/activities/detail/ec17ae2a-032e-49fc-8cdb-c86a097d3a2d?year=2026
Authorization: Bearer {{token}}

### get activity detail for a year and month
GET {{host}}/activities/detail/ec17ae2a-032e-49fc-8cdb-c86a097d3a2d?year=2026&&month=05
Authorization: Bearer {{token}}

### get activity detail without info
GET {{host}}/activities/detail/ec17ae2a-032e-49fc-8cdb-c86a097d3a2d
Authorization: Bearer {{token}}

### get activities details by month
GET {{host}}/activities/detail?month=3
Authorization: Bearer {{token}}

### get activities details by month
GET {{host}}/activities/detail?year=2025
Authorization: Bearer {{token}}

### get activities details without info
GET {{host}}/activities/detail
Authorization: Bearer {{token}}